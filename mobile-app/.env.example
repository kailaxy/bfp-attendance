# Mobile API mode:
# - mock (safe default, no backend call)
# - live (calls Apps Script endpoint)
EXPO_PUBLIC_API_MODE=mock

# Set only when EXPO_PUBLIC_API_MODE=live
# Example:
# EXPO_PUBLIC_APPS_SCRIPT_BASE_URL=https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec
EXPO_PUBLIC_APPS_SCRIPT_BASE_URL=

# Optional request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT_MS=15000

# Scan location is captured when available and sent as metadata with each scan.
# No geofence blocking is applied in the mobile app.
